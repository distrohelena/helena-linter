{
    "name": "@distrohelena/linter",
    "version": "0.5.0",
    "description": "Helena TypeScript lint rules for ESLint flat config.",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/distrohelena/helena-linter.git"
    },
    "homepage": "https://github.com/distrohelena/helena-linter",
    "bugs": {
        "url": "https://github.com/distrohelena/helena-linter/issues"
    },
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./control-body-braces": {
            "types": "./dist/control-body-braces.d.ts",
            "import": "./dist/control-body-braces.js"
        },
        "./control-block-following-spacing": {
            "types": "./dist/control-block-following-spacing.d.ts",
            "import": "./dist/control-block-following-spacing.js"
        },
        "./declaration-leading-spacing": {
            "types": "./dist/declaration-leading-spacing.d.ts",
            "import": "./dist/declaration-leading-spacing.js"
        },
        "./declaration-spacing": {
            "types": "./dist/declaration-spacing.d.ts",
            "import": "./dist/declaration-spacing.js"
        },
        "./early-return": {
            "types": "./dist/early-return.d.ts",
            "import": "./dist/early-return.js"
        },
        "./exit-spacing": {
            "types": "./dist/exit-spacing.d.ts",
            "import": "./dist/exit-spacing.js"
        },
        "./if-else-if-chain": {
            "types": "./dist/if-else-if-chain.d.ts",
            "import": "./dist/if-else-if-chain.js"
        },
        "./if-leading-spacing": {
            "types": "./dist/if-leading-spacing.d.ts",
            "import": "./dist/if-leading-spacing.js"
        },
        "./if-following-spacing": {
            "types": "./dist/if-following-spacing.d.ts",
            "import": "./dist/if-following-spacing.js"
        },
        "./multiline-block-layout": {
            "types": "./dist/multiline-block-layout.d.ts",
            "import": "./dist/multiline-block-layout.js"
        },
        "./redundant-else-if": {
            "types": "./dist/redundant-else-if.d.ts",
            "import": "./dist/redundant-else-if.js"
        }
    },
    "files": [
        "dist"
    ],
    "license": "MIT",
    "private": false,
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "build": "tsc -p tsconfig.build.json",
        "test": "vitest run",
        "lint": "eslint . --max-warnings=0",
        "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\" \"scripts/**/*.mjs\" \"*.{js,json,md}\"",
        "lint:smoke": "node scripts/run-smoke-test.mjs"
    },
    "devDependencies": {
        "@typescript-eslint/eslint-plugin": "^8.57.1",
        "@typescript-eslint/parser": "^8.57.1",
        "@typescript-eslint/rule-tester": "^8.57.1",
        "@typescript-eslint/utils": "^8.57.1",
        "eslint": "^10.0.3",
        "prettier": "^3.8.1",
        "typescript": "^5.9.3",
        "vitest": "^4.1.0"
    },
    "peerDependencies": {
        "@typescript-eslint/parser": "^8.57.1",
        "eslint": "^10.0.3",
        "typescript": "^5.9.3"
    }
}
